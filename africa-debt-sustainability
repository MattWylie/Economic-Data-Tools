const NORTH_AFRICA_IDS = new Set([12, 818, 434, 504, 788, 732]);
const SSA_IDS          = new Set(Object.keys(SSA).map(Number));
const ALL_AFRICA_IDS   = new Set([...SSA_IDS, ...NORTH_AFRICA_IDS]);

// ── Indicator definitions ──────────────────────────────────────────────────────
const INDICATOR_KEYS = ['debt', 'interest', 'fiscal', 'external', 'growth'];

const INDICATORS = {
  debt:     'GC.DOD.TOTL.GD.ZS',
  interest: 'GC.INT.TOTL.RV.ZS',
  fiscal:   'GC.BAL.CASH.GD.ZS',
  external: 'DT.DOD.DECT.GD.ZS',
  growth:   'NY.GDP.MKTP.KD.ZG',
};

const WEIGHTS = { debt:0.30, interest:0.25, fiscal:0.20, external:0.15, growth:0.10 };

const LABELS = {
  debt:     'Govt Debt / GDP',
  interest: 'Interest / Revenue',
  fiscal:   'Fiscal Balance / GDP',
  external: 'External Debt / GNI',
  growth:   'GDP Growth',
};

const RADAR_LABELS = {
  debt:     ['Govt Debt', '/ GDP'],
  interest: ['Interest', '/ Revenue'],
  fiscal:   ['Fiscal', 'Balance'],
  external: ['External', 'Debt / GNI'],
  growth:   ['GDP', 'Growth'],
};

// ── Scoring ────────────────────────────────────────────────────────────────────
function piecewise(v, pts) {
  if (v <= pts[0][0])              return pts[0][1];
  if (v >= pts[pts.length - 1][0]) return pts[pts.length - 1][1];
  for (let i = 0; i < pts.length - 1; i++) {
    const [x0, y0] = pts[i];
    const [x1, y1] = pts[i + 1];
    if (v >= x0 && v <= x1) return y0 + (y1 - y0) * (v - x0) / (x1 - x0);
  }
}

const SCORE_FNS = {
  debt:     v => piecewise(v, [[0,100],[30,70],[55,30],[80,0]]),
  interest: v => piecewise(v, [[0,100],[10,70],[22.5,30],[35,0]]),
  fiscal:   v => piecewise(v, [[-10,0],[-5,30],[0,60],[5,100]]),
  external: v => piecewise(v, [[0,100],[30,70],[55,30],[80,0]]),
  growth:   v => piecewise(v, [[-5,0],[0,40],[4,70],[7,100]]),
};

function computeScore(rawData) {
  let weightSum = 0, scoreSum = 0;
  const componentScores = {};
  for (const key of INDICATOR_KEYS) {
    if (rawData[key] != null) {
      const s = Math.max(0, Math.min(100, SCORE_FNS[key](rawData[key].value)));
      componentScores[key] = s;
      scoreSum  += s * WEIGHTS[key];
      weightSum += WEIGHTS[key];
    }
  }
  if (weightSum < 0.30) return null;
  const raw = weightSum < 1 ? scoreSum / weightSum : scoreSum;
  return { score: Math.round(raw), components: componentScores, weightUsed: weightSum };
}

function riskCategory(score) {
  if (score >= 75) return { label:'Low risk',       cls:'risk-low',       symbol:'✓' };
  if (score >= 50) return { label:'Moderate risk',  cls:'risk-moderate',  symbol:'~' };
  if (score >= 25) return { label:'High risk',      cls:'risk-high',      symbol:'!' };
  return               { label:'Very high risk',  cls:'risk-very-high', symbol:'⚠' };
}

// ── Color scale (red → yellow → green, 0–100) ─────────────────────────────────
const colorScale   = d3.scaleSequential([0, 100], d3.interpolateRdYlGn);
const FILL_NODATA  = '#21262d';
const FILL_NAFR    = '#151c2a';
const FILL_OTHER   = '#080c14';
const STROKE_AFRIC = '#1f2937';

// ── Tooltip ────────────────────────────────────────────────────────────────────
const tooltip = document.getElementById('tooltip');

function showTooltip(event, info, scored) {
  document.getElementById('tip-name').textContent = info.name;
  const body = document.getElementById('tip-body');
  if (scored) {
    const rc  = riskCategory(scored.score);
    const col = colorScale(scored.score);
    const partial = scored.weightUsed < 0.99
      ? `<div class="tip-hint">Partial data (${Math.round(scored.weightUsed * 100)}% weight covered)</div>` : '';
    body.innerHTML = `
      <div class="tip-score-row">
        <span class="tip-score" style="color:${col}">${scored.score}</span>
        <span class="tip-score-denom">/ 100</span>
      </div>
      <span class="tip-risk ${rc.cls}">${rc.symbol} ${rc.label}</span>
      <div class="tip-components" style="margin-top:0.45rem">
        ${INDICATOR_KEYS.filter(k => scored.components[k] !== undefined).map(k => `
          <div class="tip-comp-row">
            <span>${LABELS[k]}</span>
            <span class="tip-comp-val">${scored.components[k].toFixed(0)}/100</span>
          </div>`).join('')}
      </div>
      ${partial}
      <div class="tip-hint" style="margin-top:0.35rem">Click for full breakdown</div>`;
  } else {
    body.innerHTML = `<p class="tip-nodata">No data available</p>`;
  }
  tooltip.style.opacity = '1';
  positionTooltip(event);
}

function positionTooltip(event) {
  const tw = tooltip.offsetWidth, th = tooltip.offsetHeight;
  let x = event.clientX + 14, y = event.clientY - 10;
  if (x + tw > window.innerWidth  - 12) x = event.clientX - tw - 14;
  if (y + th > window.innerHeight - 12) y = event.clientY - th - 10;
  tooltip.style.left = x + 'px';
  tooltip.style.top  = y + 'px';
}

function hideTooltip() { tooltip.style.opacity = '0'; }

// ── Detail panel ───────────────────────────────────────────────────────────────
document.getElementById('panel-close').addEventListener('click', closePanel);

function openPanel(info, scored, rawData) {
  document.getElementById('panel-name').textContent = info.name;
  const rc  = riskCategory(scored.score);
  const col = colorScale(scored.score);

  const numEl = document.getElementById('panel-score-number');
  numEl.textContent  = scored.score;
  numEl.style.color  = col;

  const badge = document.getElementById('panel-risk-badge');
  badge.textContent = `${rc.symbol} ${rc.label}`;
  badge.className   = `panel-risk-badge ${rc.cls}`;

  drawRadar(scored.components);

  document.getElementById('panel-components').innerHTML =
    INDICATOR_KEYS.map(k => {
      const raw   = rawData[k];
      const s     = scored.components[k];
      const val   = raw != null ? `${raw.value.toFixed(1)}% (${raw.year})` : 'No data';
      const barW  = s != null ? s : 0;
      const barC  = s != null ? colorScale(s) : '#21262d';
      return `
        <div class="panel-comp">
          <div class="panel-comp-header">
            <span class="panel-comp-name">${LABELS[k]}</span>
            <span class="panel-comp-val">${val}</span>
          </div>
          <div class="panel-bar-bg">
            <div class="panel-bar-fill" style="width:${barW}%;background:${barC}"></div>
          </div>
        </div>`;
    }).join('');

  document.getElementById('panel-note').textContent =
    scored.weightUsed < 0.99
      ? `Score computed from ${Math.round(scored.weightUsed * 100)}% of total indicator weight due to missing data — interpret with caution.`
      : 'All five indicators available for this country.';

  document.getElementById('detail-panel').classList.add('open');
}

function closePanel() {
  document.getElementById('detail-panel').classList.remove('open');
}

// ── Radar chart ────────────────────────────────────────────────────────────────
function drawRadar(components) {
  const svgEl = document.getElementById('panel-radar');
  svgEl.innerHTML = '';

  const size = svgEl.clientWidth || 268;
  const cx = size / 2, cy = size / 2;
  const R  = size * 0.33;
  const LR = R * 1.32;
  const n  = INDICATOR_KEYS.length;
  const slice = (2 * Math.PI) / n;

  const svg = d3.select('#panel-radar').attr('viewBox', `0 0 ${size} ${size}`);

  // Grid circles
  [25, 50, 75, 100].forEach(lvl => {
    svg.append('circle')
      .attr('cx', cx).attr('cy', cy)
      .attr('r', R * lvl / 100)
      .attr('fill', 'none')
      .attr('stroke', lvl === 50 ? '#30363d' : '#21262d')
      .attr('stroke-width', 0.8);
  });
  svg.append('text')
    .attr('x', cx + 3).attr('y', cy - R * 0.5 + 9)
    .attr('font-size', 7).attr('fill', '#484f58')
    .text('50');

  // Axes + labels
  INDICATOR_KEYS.forEach((k, i) => {
    const angle = slice * i - Math.PI / 2;
    const x2 = cx + R * Math.cos(angle);
    const y2 = cy + R * Math.sin(angle);

    svg.append('line')
      .attr('x1', cx).attr('y1', cy)
      .attr('x2', x2).attr('y2', y2)
      .attr('stroke', '#30363d').attr('stroke-width', 1);

    const lx = cx + LR * Math.cos(angle);
    const ly = cy + LR * Math.sin(angle);
    const anchor = Math.abs(Math.cos(angle)) < 0.15 ? 'middle'
                 : Math.cos(angle) > 0 ? 'start' : 'end';

    const lines = RADAR_LABELS[k];
    const textEl = svg.append('text')
      .attr('text-anchor', anchor)
      .attr('dominant-baseline', 'middle');
    lines.forEach((line, li) => {
      textEl.append('tspan')
        .attr('x', lx)
        .attr('dy', li === 0 ? (ly - (lines.length - 1) * 5.5) + 'px' : 11)
        .attr('y', li === 0 ? ly - (lines.length - 1) * 5.5 : null)
        .attr('font-size', 8).attr('fill', '#6e7681')
        .text(line);
    });
  });

  // Data polygon
  const pts = INDICATOR_KEYS.map((k, i) => {
    const angle = slice * i - Math.PI / 2;
    const r = R * (components[k] ?? 0) / 100;
    return [cx + r * Math.cos(angle), cy + r * Math.sin(angle)];
  });

  svg.append('polygon')
    .attr('points', pts.map(p => p.join(',')).join(' '))
    .attr('fill', 'rgba(88,166,255,0.12)')
    .attr('stroke', '#58a6ff')
    .attr('stroke-width', 1.5)
    .attr('stroke-linejoin', 'round');

  INDICATOR_KEYS.forEach((k, i) => {
    const angle = slice * i - Math.PI / 2;
    const s = components[k] ?? 0;
    const r = R * s / 100;
    svg.append('circle')
      .attr('cx', cx + r * Math.cos(angle))
      .attr('cy', cy + r * Math.sin(angle))
      .attr('r', 3)
      .attr('fill', colorScale(s))
      .attr('stroke', '#161b22').attr('stroke-width', 1.2);
  });
}

// ── Map ────────────────────────────────────────────────────────────────────────
function drawMap(world, scoreMap, rawMap) {
  const container = document.getElementById('map-container');
  const W = container.clientWidth || 820;
  const H = Math.round(W * 1.18);

  const svg = d3.select('#map-svg')
    .attr('viewBox', `0 0 ${W} ${H}`)
    .attr('preserveAspectRatio', 'xMidYMid meet');

  const countries = topojson.feature(world, world.objects.countries);
  const africaGeoJSON = {
    type: 'FeatureCollection',
    features: countries.features.filter(f => ALL_AFRICA_IDS.has(+f.id))
  };

  const projection = d3.geoNaturalEarth1()
    .fitExtent([[28, 24], [W - 28, H - 24]], africaGeoJSON);
  const path = d3.geoPath().projection(projection);

  svg.append('rect').attr('width', W).attr('height', H).attr('fill', FILL_OTHER);

  svg.append('g')
    .selectAll('path')
    .data(countries.features)
    .join('path')
      .attr('class', d => SSA_IDS.has(+d.id) ? 'country-path country-ssa' : 'country-path')
      .attr('d', d => path(d) || '')
      .attr('fill', d => {
        const id = +d.id;
        if (SSA_IDS.has(id)) {
          const sc = scoreMap[SSA[id].iso2];
          return sc ? colorScale(sc.score) : FILL_NODATA;
        }
        return NORTH_AFRICA_IDS.has(id) ? FILL_NAFR : FILL_OTHER;
      })
      .attr('stroke', d => ALL_AFRICA_IDS.has(+d.id) ? STROKE_AFRIC : 'none')
      .attr('stroke-width', d => ALL_AFRICA_IDS.has(+d.id) ? 0.6 : 0)
      .on('mousemove', function(event, d) {
        const id   = +d.id;
        const info = SSA[id];
        if (!info) return;
        showTooltip(event, info, scoreMap[info.iso2]);
        d3.select(this).raise().attr('stroke', '#e2e8f0').attr('stroke-width', 1.8);
        positionTooltip(event);
      })
      .on('mouseleave', function(_, d) {
        hideTooltip();
        const id = +d.id;
        d3.select(this)
          .attr('stroke',       ALL_AFRICA_IDS.has(id) ? STROKE_AFRIC : 'none')
          .attr('stroke-width', ALL_AFRICA_IDS.has(id) ? 0.6 : 0);
      })
      .on('click', function(_, d) {
        const id   = +d.id;
        const info = SSA[id];
        if (!info) return;
        const sc = scoreMap[info.iso2];
        if (!sc) return;
        hideTooltip();
        openPanel(info, sc, rawMap[info.iso2] || {});
      });
}

// ── Legend ─────────────────────────────────────────────────────────────────────
function drawLegend() {
  const container = document.getElementById('legend');
  const padL = 10, padR = 10;
  const barW = (container.clientWidth || 520) - padL - padR - 2;
  const barH = 14, barY = 16;

  document.getElementById('legend-svg').setAttribute('viewBox', `0 0 ${barW + padL + padR} 62`);
  const svg = d3.select('#legend-svg');

  const defs = svg.append('defs');
  const grad = defs.append('linearGradient').attr('id', 'dsi-grad');
  for (let i = 0; i <= 60; i++) {
    const t = i / 60;
    grad.append('stop').attr('offset', `${t * 100}%`).attr('stop-color', colorScale(t * 100));
  }

  const g = svg.append('g').attr('transform', `translate(${padL},0)`);
  g.append('rect').attr('y', barY).attr('width', barW).attr('height', barH).attr('rx', 4).attr('fill', 'url(#dsi-grad)');

  // Band dividers at 25, 50, 75
  [25, 50, 75].forEach(v => {
    const x = (v / 100) * barW;
    g.append('line')
      .attr('x1', x).attr('x2', x)
      .attr('y1', barY - 2).attr('y2', barY + barH + 2)
      .attr('stroke', '#0d1117').attr('stroke-width', 1.5);
  });

  // Tick labels
  [0, 25, 50, 75, 100].forEach(v => {
    const x = (v / 100) * barW;
    g.append('text')
      .attr('x', x).attr('y', barY + barH + 13)
      .attr('text-anchor', v === 0 ? 'start' : v === 100 ? 'end' : 'middle')
      .attr('font-size', 8.5).attr('fill', '#6e7681')
      .text(v);
  });

  // Risk band labels
  [
    { cx: 12.5, label: 'Very High' },
    { cx: 37.5, label: 'High' },
    { cx: 62.5, label: 'Moderate' },
    { cx: 87.5, label: 'Low Risk' },
  ].forEach(({ cx, label }) => {
    g.append('text')
      .attr('x', (cx / 100) * barW).attr('y', barY + barH + 28)
      .attr('text-anchor', 'middle')
      .attr('font-size', 7.5).attr('fill', '#484f58')
      .text(label);
  });

  // No-data swatch
  g.append('rect').attr('x', barW - 68).attr('y', barY + barH + 18).attr('width', 10).attr('height', 10).attr('rx', 2).attr('fill', FILL_NODATA);
  g.append('text').attr('x', barW - 54).attr('y', barY + barH + 27).attr('font-size', 8.5).attr('fill', '#6e7681').text('No data');
}

// ── Stats panel ────────────────────────────────────────────────────────────────
function updateStats(scoreMap) {
  const scores = Object.values(scoreMap).map(d => d.score);
  if (!scores.length) return;

  const lowRisk = scores.filter(s => s >= 75).length;
  const avg     = scores.reduce((a, b) => a + b, 0) / scores.length;
  let bestIso = null, bestVal = -Infinity;
  for (const [iso2, d] of Object.entries(scoreMap)) {
    if (d.score > bestVal) { bestVal = d.score; bestIso = iso2; }
  }
  const bestName = Object.values(SSA).find(d => d.iso2 === bestIso)?.name || '';

  document.getElementById('stat-count').textContent     = scores.length;
  document.getElementById('stat-low').textContent       = lowRisk;
  document.getElementById('stat-avg').textContent       = avg.toFixed(0);
  document.getElementById('stat-best').textContent      = bestVal;
  document.getElementById('stat-best-name').textContent = bestName;
}

// ── Data fetching ──────────────────────────────────────────────────────────────
async function fetchIndicator(key) {
  const code    = INDICATORS[key];
  const iso2str = Object.values(SSA).map(d => d.iso2).join(';');
  const url     = `https://api.worldbank.org/v2/country/${iso2str}/indicator/${code}?format=json&mrv=5&per_page=500`;
  const raw     = await d3.json(url);
  const result  = {};
  if (raw?.[1]) {
    raw[1].forEach(row => {
      const iso2 = row.country?.id;
      if (iso2 && row.value !== null && !result[iso2]) {
        result[iso2] = { value: row.value, year: row.date };
      }
    });
  }
  return result;
}

// ── Init ───────────────────────────────────────────────────────────────────────
async function init() {
  try {
    const [world, ...fetched] = await Promise.all([
      d3.json('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-50m.json'),
      ...INDICATOR_KEYS.map(fetchIndicator),
    ]);

    // Build per-country raw data map
    const rawMap = {};
    INDICATOR_KEYS.forEach((key, i) => {
      for (const [iso2, data] of Object.entries(fetched[i])) {
        if (!rawMap[iso2]) rawMap[iso2] = {};
        rawMap[iso2][key] = data;
      }
    });

    // Compute composite scores
    const scoreMap = {};
    for (const [iso2, rawData] of Object.entries(rawMap)) {
      const result = computeScore(rawData);
      if (result) scoreMap[iso2] = result;
    }

    drawMap(world, scoreMap, rawMap);
    drawLegend();
    updateStats(scoreMap);

    document.getElementById('loading').style.display   = 'none';
    document.getElementById('legend').style.visibility = 'visible';
    document.getElementById('stats').style.visibility  = 'visible';

  } catch (err) {
    console.error(err);
    document.getElementById('loading').innerHTML = `
      <div style="color:#ef4444;font-size:0.88rem;padding:2.5rem;text-align:center;max-width:340px">
        ⚠️ Could not load data.<br>
        <span style="color:#8b949e;font-size:0.78rem">
          Check your internet connection and reload.<br><br>
          (World Bank API and jsDelivr CDN must be reachable.)
        </span>
      </div>`;
  }
}

init();
</script>
